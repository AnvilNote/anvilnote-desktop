{
  "name": "anvilnote",
  "version": "0.1.14",
  "private": true,
  "license": "MIT",
  "description": "Offline-first writing and notes app",
  "author": {
    "name": "AnvilNote",
    "email": "sungpinyue@gmail.com"
  },
  "homepage": "https://github.com/AnvilNote/anvilnote-desktop",
  "type": "module",
  "main": "dist/main/main.js",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "check": "node --version",
    "test": "pnpm build:main && node --test test/**/*.test.mjs",
    "clean": "node scripts/clean.mjs",
    "check:repos": "node scripts/ensure-sibling-repos.mjs",
    "build:web": "node scripts/build-web.mjs",
    "build:api": "node scripts/build-api.mjs",
    "build:renderer": "node scripts/build-renderer.mjs",
    "copy:web": "node scripts/copy-web.mjs",
    "copy:api": "node scripts/copy-api.mjs",
    "copy:renderer": "node scripts/copy-renderer.mjs",
    "copy:resources": "node scripts/copy-resources.mjs",
    "prepare:desktop": "node scripts/prepare-desktop.mjs",
    "build:main": "tsc -p tsconfig.json",
    "dev": "pnpm build:main && electron dist/main/main.js",
    "pack": "pnpm prepare:desktop && pnpm build:main && electron-builder --mac dir --config electron-builder.config.cjs",
    "dist:dmg": "pnpm prepare:desktop && pnpm build:main && electron-builder --mac dmg --config electron-builder.config.cjs",
    "dist:pkg": "pnpm prepare:desktop && pnpm build:main && electron-builder --mac pkg --config electron-builder.config.cjs",
    "dist:mac": "pnpm prepare:desktop && pnpm build:main && electron-builder --mac dmg pkg --config electron-builder.config.cjs",
    "fetch:typst:linux": "node scripts/fetch-typst-linux.mjs",
    "fetch:pandoc:linux": "node scripts/fetch-pandoc-linux.mjs",
    "dist:linux": "node scripts/dist-linux.mjs",
    "fetch:typst:windows": "node scripts/fetch-typst-windows.mjs",
    "fetch:pandoc:windows": "node scripts/fetch-pandoc-windows.mjs",
    "dist:win": "pnpm prepare:desktop && pnpm fetch:typst:windows && pnpm fetch:pandoc:windows && pnpm build:main && electron-builder --win nsis --x64 --config electron-builder.config.cjs"
  },
  "dependencies": {
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.3"
  }
}
